# Aomi runtime (used by AomiFrame — see src/components/aomi-frame.tsx)
# Browser requests use same-origin /api/aomi (proxied in next.config.ts) to avoid CORS.
NEXT_PUBLIC_BACKEND_URL=/api/aomi
# Upstream API for the proxy (server-only; optional if NEXT_PUBLIC_BACKEND_URL is a full URL):
AOMI_BACKEND_PROXY_TARGET=https://api.aomi.dev
# Local Aomi backend:
# AOMI_BACKEND_PROXY_TARGET=http://localhost:8080

# Aomi API key (sk-...) — powers /agent-chat when set (hides manual key entry).
# Users can also enter a key in the chat control bar if this is unset.
# Obtain from https://aomi.dev after your app is provisioned.
# AOMI_API_KEY=

# Para wallet (when you wire @getpara/react-sdk + wagmi providers)
# NEXT_PUBLIC_PARA_API_KEY=

# OpenRouter (server-only)
OPENROUTER_API_KEY=

# Base mainnet chain id
NEXT_PUBLIC_CHAIN_ID=8453

# Public site URL for WalletConnect metadata (optional; defaults to window origin in browser)
# NEXT_PUBLIC_APP_URL=https://aeroroute.ai

# WalletConnect Cloud project id — also add your Vercel domain under Allowed Domains in Reown Cloud.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
