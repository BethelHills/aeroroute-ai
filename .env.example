# Aomi runtime (used by AomiFrame — see src/components/aomi-frame.tsx)
# Production hosted API:
NEXT_PUBLIC_BACKEND_URL=https://api.aomi.dev
# Local Aomi backend (uncomment for local stack development):
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Aomi API key (sk-...) — optional if users enter keys in the chat control bar.
# Obtain from https://aomi.dev after your app is provisioned.
# AOMI_API_KEY=

# Para wallet (when you wire @getpara/react-sdk + wagmi providers)
# NEXT_PUBLIC_PARA_API_KEY=

# OpenRouter (server-only)
OPENROUTER_API_KEY=

# Base mainnet chain id
NEXT_PUBLIC_CHAIN_ID=8453

# WalletConnect Cloud project id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
